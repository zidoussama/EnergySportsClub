html {
  font-size: 14px;
}

@media (min-width: 768px) {
  html {
    font-size: 16px;
  }
}

.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.1rem rgba(255, 255, 255, 0.5), 0 0 0 0.25rem rgba(109, 40, 217, 0.22);
}

html {
  position: relative;
  min-height: 100%;
}

body {
  margin-bottom: 0;
  background:
    radial-gradient(circle at top left, rgba(109, 40, 217, 0.12), transparent 30%),
    linear-gradient(180deg, #f8f7ff 0%, #f5f3ff 100%);
  color: #1f2937;
  font-family: "Segoe UI", system-ui, -apple-system, sans-serif;
}

.app-body {
  min-height: 100vh;
}

.app-navbar {
  background: linear-gradient(135deg, #2e1065 0%, #4338ca 100%);
  box-shadow: 0 18px 35px rgba(46, 16, 101, 0.2);
}

.app-navbar-inner {
  padding-top: 0.75rem;
  padding-bottom: 0.75rem;
}

.app-brand {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-weight: 700;
  text-decoration: none;
}

.app-brand-mark {
  width: 2.2rem;
  height: 2.2rem;
  border-radius: 0.75rem;
  background: rgba(255, 255, 255, 0.16);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.95rem;
}

.app-top-action {
  border-radius: 999px;
  font-weight: 600;
}

.app-content {
  min-height: calc(100vh - 136px);
}

.app-footer {
  padding: 1rem 1.25rem 1.5rem;
  font-size: 0.92rem;
}

.page-title {
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 1rem;
  letter-spacing: -0.02em;
}

.card {
  border: 0;
  border-radius: 1.1rem;
  box-shadow: 0 16px 40px rgba(88, 80, 141, 0.12);
  overflow: hidden;
}

.card .card-title {
  font-weight: 700;
  color: #111827;
}

.table {
  background: #ffffff;
  border-radius: 0.9rem;
  overflow: hidden;
  box-shadow: 0 10px 24px rgba(88, 80, 141, 0.08);
}

.table thead {
  background: #ede9fe;
}

.table th {
  font-weight: 700;
  color: #3b2c85;
  border-bottom: 0;
}

.table td {
  color: #4b5563;
  border-top: 1px solid #e2e8f0;
  vertical-align: middle;
}

.btn {
  border-radius: 0.75rem;
}

.btn-primary {
  font-weight: 700;
  background: linear-gradient(135deg, #6d28d9, #8b5cf6);
  border: none;
  box-shadow: 0 12px 24px rgba(109, 40, 217, 0.22);
}

.btn-primary:hover {
  background: linear-gradient(135deg, #5b21b6, #7c3aed);
}

.btn-light {
  background: #fff;
  border-color: #fff;
  color: #2e1065;
}

.btn-outline-secondary,
.btn-outline-danger,
.btn-outline-primary {
  border-radius: 0.75rem;
}

.form-control,
.form-select {
  border-radius: 0.75rem;
  border: 1px solid #e2e8f0;
  padding: 0.7rem 0.85rem;
}

.form-control:focus,
.form-select:focus {
  border-color: #c4b5fd;
  box-shadow: 0 0 0 0.2rem rgba(139, 92, 246, 0.2);
}

.alert {
  border-radius: 0.9rem;
}

.app-shell {
  display: flex;
  min-height: 100vh;
}

.app-sidebar {
  position: fixed;
  inset: 0 auto 0 0;
  width: 280px;
  height: 100vh;
  overflow-y: auto;
  background: linear-gradient(180deg, #1e1b4b 0%, #2e1065 100%);
  color: #ede9fe;
  padding: 1.5rem 1rem;
  display: flex;
  flex-direction: column;
  box-shadow: 10px 0 30px rgba(30, 27, 75, 0.16);
}

.app-sidebar-branding {
  margin-bottom: 1.25rem;
}

.app-sidebar-brand {
  color: #fff;
  width: 100%;
  margin-bottom: 0.5rem;
}

.app-sidebar-brand:hover {
  color: #fff;
}

.app-sidebar-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 0.3rem 0.75rem;
  font-size: 0.74rem;
  background: rgba(255, 255, 255, 0.14);
  color: #e9d5ff;
}

.app-sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.app-sidebar-nav .nav-link {
  color: #e9d5ff;
  border-radius: 0.75rem;
  padding: 0.65rem 0.85rem;
  font-weight: 600;
}

.app-sidebar-nav .nav-link:hover,
.app-sidebar-nav .nav-link.active {
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
}

.app-sidebar-footer {
  margin-top: auto;
  padding-top: 1.25rem;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.profile-dropdown {
  position: relative;
}

.btn-profile {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  width: 100%;
  border: 0;
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  padding: 0.8rem 0.9rem;
  text-align: left;
}

.btn-profile:hover,
.btn-profile:focus {
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
}

.btn-profile::after {
  margin-left: auto;
}

.profile-avatar {
  width: 2.25rem;
  height: 2.25rem;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  background: rgba(255, 255, 255, 0.18);
  font-weight: 800;
}

.profile-label {
  display: inline-flex;
  flex-direction: column;
  line-height: 1.1;
}

.profile-menu {
  min-width: 16rem;
  border: 0;
  border-radius: 1rem;
  box-shadow: 0 18px 35px rgba(30, 27, 75, 0.18);
  padding: 0.5rem;
}

.profile-menu .dropdown-header {
  color: #6b7280;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.profile-menu .dropdown-item {
  border-radius: 0.65rem;
  padding: 0.6rem 0.8rem;
}

.profile-menu .dropdown-item:hover {
  background: #ede9fe;
  color: #4c1d95;
}

.app-main {
  flex: 1;
  padding: 2rem;
  margin-left: 280px;
}

.app-main > .page-title:first-child,
.app-main > h1:first-child {
  margin-top: 0.25rem;
}

.sidebar-section-title {
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #c4b5fd;
  margin: 1.2rem 0 0.45rem;
}

.auth-container {
  min-height: calc(100vh - 120px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem 1rem;
}

.auth-card {
  width: 100%;
  max-width: 920px;
  border-radius: 1rem;
  box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.08);
  background: #ffffff;
}

.auth-card .auth-body {
  padding: 2.5rem;
}

.auth-panel {
  background: linear-gradient(135deg, #0d6efd, #6f42c1);
  color: #fff;
  border-radius: 0.9rem;
  padding: 2rem;
  min-height: 100%;
}

.hero-panel {
  background: linear-gradient(135deg, #2e1065 0%, #4338ca 55%, #7c3aed 100%);
  color: #fff;
  border-radius: 1.2rem;
  padding: 2.25rem;
  box-shadow: 0 22px 40px rgba(46, 16, 101, 0.22);
}

.hero-panel h1,
.hero-panel h2,
.hero-panel h3 {
  color: #fff;
}

.hero-panel .lead {
  color: rgba(255, 255, 255, 0.88);
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 1rem;
  margin-bottom: 1rem;
}

.section-header h2,
.section-header h3,
.section-header h4 {
  margin-bottom: 0;
}

.section-header .text-muted {
  margin-bottom: 0;
}

.metric-card {
  height: 100%;
}

.metric-card .card-body {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.metric-label {
  color: #6b7280;
  font-size: 0.9rem;
  font-weight: 600;
}

.metric-value {
  font-size: 2rem;
  font-weight: 800;
  line-height: 1;
  color: #111827;
}

.soft-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 0.35rem 0.75rem;
  font-weight: 700;
  background: #ede9fe;
  color: #5b21b6;
}

.surface-card {
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(8px);
}

.empty-state {
  padding: 1.25rem;
  border: 1px dashed #c4b5fd;
  border-radius: 0.9rem;
  color: #6b7280;
  background: rgba(255, 255, 255, 0.6);
}

.dashboard-grid {
  display: grid;
  gap: 1rem;
}

.dashboard-grid.two-col {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.dashboard-grid.three-col {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

@media (max-width: 992px) {
  .app-shell {
    flex-direction: column;
  }

  .app-sidebar {
    position: static;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .app-main {
    margin-left: 0;
    padding: 1.25rem;
  }

  .dashboard-grid.two-col,
  .dashboard-grid.three-col {
    grid-template-columns: 1fr;
  }
}

.form-floating > .form-control-plaintext::placeholder, .form-floating > .form-control::placeholder {
  color: var(--bs-secondary-color);
  text-align: end;
}

.form-floating > .form-control-plaintext:focus::placeholder, .form-floating > .form-control:focus::placeholder {
  text-align: start;
}
