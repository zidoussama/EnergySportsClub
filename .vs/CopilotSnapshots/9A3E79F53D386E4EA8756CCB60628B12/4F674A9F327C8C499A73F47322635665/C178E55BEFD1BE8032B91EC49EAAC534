@{
    ViewData["Title"] = "Home";
}

<div class="hero-panel mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="soft-badge mb-3">EnergySportsClub</span>
            <h1 class="display-5 mb-3">A cleaner way to manage terrains, materials, and reservations.</h1>
            <p class="lead mb-4">Modern booking experiences for clients, managers, and administrators with one consistent interface.</p>
            <div class="hero-actions">
                <a class="btn btn-light btn-lg" asp-controller="Home" asp-action="UserInterface">Client Dashboard</a>
                <a class="btn btn-outline-light btn-lg" asp-controller="Home" asp-action="ManagerDashboard">Manager Dashboard</a>
                <a class="btn btn-outline-light btn-lg" asp-controller="Home" asp-action="AdminDashboard">Admin Dashboard</a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card surface-card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Platform highlights</h5>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">Responsive dashboards for each role</li>
                        <li class="mb-2">Availability-aware reservations</li>
                        <li class="mb-2">Stock monitoring and low-stock alerts</li>
                        <li class="mb-0">Unified sidebar and card system</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Client experience</div>
                <div class="metric-value">Browse</div>
                <p class="mb-0 text-muted">Explore terrains and materials with a focused dashboard layout.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Operations</div>
                <div class="metric-value">Manage</div>
                <p class="mb-0 text-muted">Use role-specific portals for reservation and inventory control.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Insights</div>
                <div class="metric-value">Track</div>
                <p class="mb-0 text-muted">Monitor current, upcoming, and historical reservations at a glance.</p>
            </div>
        </div>
    </div>
</div>
