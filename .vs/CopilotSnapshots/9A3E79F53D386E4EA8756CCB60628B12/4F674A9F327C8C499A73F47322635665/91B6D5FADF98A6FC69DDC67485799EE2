@model EnergySportsClub.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<h1>Admin Dashboard</h1>

<div class="row">
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Total Reservations</h6>
                <h4 class="card-title">@Model.TotalReservations</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Total Terrains</h6>
                <h4 class="card-title">@Model.TotalTerrains</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Total Clients</h6>
                <h4 class="card-title">@Model.TotalClients</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Peak Hour</h6>
                <h4 class="card-title">@(Model.PeakReservationHour.HasValue ? $"{Model.PeakReservationHour:00}:00" : "-")</h4>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Reservations Today</h6>
                <h4 class="card-title">@Model.ReservationsToday</h4>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Reservations This Week</h6>
                <h4 class="card-title">@Model.ReservationsThisWeek</h4>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <h5>Reservations by Day</h5>
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Date</th>
                    <th class="text-end">Count</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.ReservationsByDay)
            {
                <tr>
                    <td>@item.Label</td>
                    <td class="text-end">@item.Count</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="col-md-6">
        <h5>Reservations by Weekday</h5>
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Day</th>
                    <th class="text-end">Count</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.ReservationsByWeekDay)
            {
                <tr>
                    <td>@item.Label</td>
                    <td class="text-end">@item.Count</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
