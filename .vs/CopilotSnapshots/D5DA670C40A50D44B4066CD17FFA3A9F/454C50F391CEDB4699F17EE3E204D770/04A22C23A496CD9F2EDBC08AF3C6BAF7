@page
@model EnergySportsClub.Areas.Admin.Pages.Users.IndexModel
@{
    ViewData["Title"] = "All Users";
    Layout = "_AdminLayout";
}

<h1>All Users</h1>

<table class="table table-striped mt-4">
    <thead>
        <tr>
            <th>Email</th>
            <th>Name</th>
            <th>Surname</th>
            <th>Roles</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var user in Model.Users)
    {
        <tr>
            <td>@user.Email</td>
            <td>@user.Name</td>
            <td>@user.Surname</td>
            <td>@string.Join(", ", user.Roles)</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@user.Id">Edit</a>
                <form method="post" asp-page-handler="Delete" asp-route-userId="@user.Id" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
