@model EnergySportsClub.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<div class="hero-panel mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
        <div>
            <span class="soft-badge mb-3">Admin overview</span>
            <h1 class="display-6 mb-2">Operational visibility at a glance.</h1>
            <p class="lead mb-0">Track reservations, clients, and usage patterns from a cleaner control center.</p>
        </div>
        <div class="hero-actions">
            <a class="btn btn-light" asp-controller="Materials" asp-action="Index">Materials</a>
            <a class="btn btn-outline-light" asp-controller="Terrains" asp-action="Index">Terrains</a>
            <a class="btn btn-outline-light" asp-controller="ReservationTerrains" asp-action="Index">Reservations</a>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Total Reservations</div>
                <div class="metric-value">@Model.TotalReservations</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Total Terrains</div>
                <div class="metric-value">@Model.TotalTerrains</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Total Clients</div>
                <div class="metric-value">@Model.TotalClients</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Peak Hour</div>
                <div class="metric-value">@(Model.PeakReservationHour.HasValue ? $"{Model.PeakReservationHour:00}:00" : "-")</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="section-header">
                    <div>
                        <h4 class="mb-1">Reservations Today</h4>
                        <p class="text-muted mb-0">Live activity for the current day.</p>
                    </div>
                    <span class="soft-badge">@Model.ReservationsToday</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="section-header">
                    <div>
                        <h4 class="mb-1">Reservations This Week</h4>
                        <p class="text-muted mb-0">Weekly booking volume.</p>
                    </div>
                    <span class="soft-badge">@Model.ReservationsThisWeek</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h4 class="mb-3">Reservations by Day</h4>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th class="text-end">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.ReservationsByDay)
                        {
                            <tr>
                                <td>@item.Label</td>
                                <td class="text-end">@item.Count</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h4 class="mb-3">Reservations by Weekday</h4>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Day</th>
                                <th class="text-end">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.ReservationsByWeekDay)
                        {
                            <tr>
                                <td>@item.Label</td>
                                <td class="text-end">@item.Count</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
