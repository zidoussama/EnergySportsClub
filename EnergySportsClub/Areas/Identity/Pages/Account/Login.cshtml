@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="row g-0">
            <div class="col-lg-6">
                <div class="auth-body">
                    <h2 class="mb-2">Welcome back</h2>
                    <p class="text-muted">Sign in to manage your reservations.</p>
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="form-label">Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="form-label">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label asp-for="Input.RememberMe" class="form-check-label">@Html.DisplayNameFor(m => m.Input.RememberMe)</label>
                        </div>
                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                        <div class="mt-3">
                            <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                        </div>
                        <div>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create a new account</a>
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="auth-panel d-flex flex-column justify-content-between">
                    <div>
                        <h3 class="mb-3">Energy Sports Club</h3>
                        <p class="mb-0">Reserve terrains and materials in seconds. Track availability and manage bookings from one place.</p>
                    </div>
                    <div>
                        <h6 class="mb-2">External sign-in</h6>
                        @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                        {
                            <small>No external authentication services configured.</small>
                        }
                        else
                        {
                            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                                <div>
                                    @foreach (var provider in Model.ExternalLogins!)
                                    {
                                        <button type="submit" class="btn btn-light btn-sm me-2" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
                                    }
                                </div>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
